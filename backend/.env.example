# Database
DATABASE_URL="postgresql://admin:secure_password@postgres:5432/agricultura_db"

# JWT
JWT_SECRET="change-this-to-a-strong-secret-in-production"
JWT_EXPIRES_IN="7d"

# ML Service
ML_SERVICE_URL="http://ml-service:5000"

# External APIs
OPENWEATHER_API_KEY="your-openweather-api-key"

# n8n
N8N_WEBHOOK_URL="http://n8n:5678/webhook"
N8N_CLIMATE_WEBHOOK_URL="http://n8n:5678/webhook/climate-ingest"
N8N_API_URL="http://n8n:5678"
N8N_BASIC_AUTH_USER="admin"
N8N_BASIC_AUTH_PASSWORD="admin123"
WORKFLOW_SECRET="change-this-workflow-secret"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
